ENV=local

# Postgres (local machine)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/stockpilot

# Redis (optional). Leave empty to use in-process rate limiting.
REDIS_URL=

# JWT (required)
JWT_SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# Frontend origin
CORS_ALLOW_ORIGINS=["http://localhost:5173"]

# Tokens
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=14

# Rate limiting (per IP, per minute)
RATE_LIMIT_PER_MINUTE=120

# AI (optional; provider wiring is stubbed unless you implement it)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Qdrant (optional for RAG). Leave as localhost only if you run qdrant locally.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Uploads (local folder)
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_MB=20
